<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/manage_meters"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/meterSerialInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/meter_number"
        android:minHeight="48dp" />

    <Spinner
        android:id="@+id/propertySpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/saveMeterButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save_meter"
        android:layout_marginTop="24dp" />

    <ListView
        android:id="@+id/meterListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

</LinearLayout>